# ---- Window area lights (cool daylight from outside) ----
light {
    type      = AREA_RECT
    pos       = 3.080 0.140 1.450
    normal    = -1.000 0.000 0.000
    size      = 0.850 0.560 0.000
    emission  = 0.620 0.760 1.000
    intensity = 0.35
    enabled   = true
}
