# Table close split essential scene — rebalanced lighting variant.
#
# 运行方式：
#   ./build/Project2Renderer assets/models/the_blender_scene the_blender_scene_table_close_split_essential_rebalanced 1200x600 64

render {
    width                = 1200
    height               = 600
    spp                  = 64
    depth                = 8
    shadows              = true
    adaptiveSampling     = true
    adaptiveMinSpp       = 16
    adaptiveBatch        = 8
    adaptiveThreshold    = 0.08
    exposure             = 1.2
    toneMap              = true
    denoise              = true
    denoiseRadius        = 3
    denoiseSigmaSpatial  = 2.0
    denoiseSigmaColor    = 0.15
    denoiseSigmaNormal   = 0.2
    denoiseSigmaAlbedo   = 0.25
    bg                   = 0.005 0.005 0.008
}

camera {
    pos       = 1.430 1.100 0.820
    lookAt    = 2.470 0.960 0.420
    up        = 0.021 0.999 -0.034
    fov       = 62
    aperture  = 0.0
    focus     = 1.12
}

envmap "../../envmaps/typewriter_studio_soft.hdr" {
    intensity = 0.10
    rotationY = 0.0
}

mesh "split_objs/Book2.obj" {
    materialMap = "split_materialmaps/Book2.materialmap"
    offset      = 0.0 0.0 0.0
    rotation    = 0.0 0.0 0.0
    scale       = 1.0 1.0 1.0
}
