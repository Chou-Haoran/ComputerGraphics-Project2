# Blender 导出的复古房间 — 重新平衡灯光版本。
#
# 灯光逻辑：
#   envmap (0.10)   → 环境基光 + 冷暖底色
#   window ×2       → 窗外冷日光，通过 shadowTransmission 穿过玻璃/窗帘
#   ceiling ×3      → 天花板暖色吊灯组
#   desk lamp ×1    → 桌面重点暖光
#   directional     → 已移除(与窗户光方向冲突)
#
# 运行方式：
#   ./build/Project2Renderer assets/models/the_blender_scene the_blender_scene 1200x600 64

render {
    width                = 1200
    height               = 600
    spp                  = 64
    depth                = 8
    shadows              = true
    adaptiveSampling     = true
    adaptiveMinSpp       = 16
    adaptiveBatch        = 8
    adaptiveThreshold    = 0.08
    exposure             = 1.2
    toneMap              = true
    denoise              = true
    denoiseRadius        = 3
    denoiseSigmaSpatial  = 2.0
    denoiseSigmaColor    = 0.15
    denoiseSigmaNormal   = 0.2
    denoiseSigmaAlbedo   = 0.25
    bg                   = 0.005 0.005 0.008
}

camera {
    pos       = -0.490 1.220 1.652
    lookAt    = 2.423 0.950 0.388
    up        = 0.021 0.999 -0.034
    fov       = 68
    aperture  = 0.0
    focus     = 3.18
}

envmap "../../envmaps/typewriter_studio_soft.hdr" {
    intensity = 0.10
    rotationY = 0.0
}

mesh "blender.obj" {
    materialMap = "the_blender_scene_export.materialmap"
    offset      = 0.0 0.0 0.0
    rotation    = 0.0 0.0 0.0
    scale       = 1.0 1.0 1.0
}

# ---- Window area lights (cool daylight from outside) ----
light {
    type      = AREA_RECT
    pos       = 3.080 0.140 1.450
    normal    = -1.000 0.000 0.000
    size      = 0.850 0.560 0.000
    emission  = 0.620 0.760 1.000
    intensity = 0.35
    enabled   = true
}

light {
    type      = AREA_RECT
    pos       = 3.080 2.140 1.450
    normal    = -1.000 0.000 0.000
    size      = 0.850 0.560 0.000
    emission  = 0.620 0.760 1.000
    intensity = 0.35
    enabled   = true
}

# ---- Ceiling pendant warm lights (reduced from 5 to 3) ----
light {
    type      = AREA_SPHERE
    pos       = 0.370 2.572 -0.040
    radius    = 0.120
    emission  = 1.000 0.823 0.533
    intensity = 80.0
    enabled   = true
}

light {
    type      = AREA_SPHERE
    pos       = 0.369 2.572 -0.921
    radius    = 0.120
    emission  = 1.000 0.752 0.450
    intensity = 80.0
    enabled   = true
}

light {
    type      = AREA_SPHERE
    pos       = -0.416 2.572 -0.471
    radius    = 0.120
    emission  = 1.000 0.773 0.354
    intensity = 80.0
    enabled   = true
}

# ---- Desk lamp (warm accent on tabletop) ----
light {
    type      = AREA_SPHERE
    pos       = 2.384 1.491 1.412
    radius    = 0.120
    emission  = 1.000 0.731 0.389
    intensity = 60.0
    enabled   = true
}
