# 参考 2nd Place.. Simon Kallweit.jpg 重排的桌面近景。
#
# 运行方式：
#   ./build/Project2Renderer assets/models/the_blender_scene_typewriter the_blender_scene_typewriter 1280x720 64

render {
    width                = 1280
    height               = 720
    spp                  = 64
    depth                = 8
    shadows              = true
    adaptiveSampling     = true
    adaptiveMinSpp       = 16
    adaptiveBatch        = 8
    adaptiveThreshold    = 0.08
    denoise              = true
    denoiseRadius        = 3
    denoiseSigmaSpatial  = 2.0
    denoiseSigmaColor    = 0.15
    denoiseSigmaNormal   = 0.2
    denoiseSigmaAlbedo   = 0.25
    bg                   = 0.005 0.005 0.008
}

camera {
    # 低机位贴近桌缘，强调左前景打字机和右后电话。
    pos       = 1.400 1.080 0.900
    lookAt    = 2.580 0.980 0.520
    up        = 0.0 1.0 0.0
    fov       = 56
    aperture  = 0.010
    focus     = 1.04
}
envmap "../../envmaps/typewriter_studio_soft.hdr" {
    intensity = 0.035
    rotationY = 0.0
}

mesh "split_objs/Carpet01.obj" {
    materialMap = "split_materialmaps/Carpet01.materialmap"
    offset      = 0.0 0.0 0.0
    rotation    = 0.0 0.0 0.0
    scale       = 1.0 1.0 1.0
}

