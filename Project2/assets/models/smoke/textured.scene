# Smoke test with a tiny 2x2 texture on the floor.
render {
    width   = 256
    height  = 256
    spp     = 16
    depth   = 6
    shadows = true
    bg      = 0.02 0.02 0.03
}

camera {
    pos     = 0.0 0.6 -1.8
    lookAt  = 0.0 0.0  0.0
    up      = 0.0 1.0  0.0
    fov     = 40
}

mesh "floor_uv.obj" {
    material   = DIFFUSE
    color      = 1.0 1.0 1.0
    diffuseTex = "../../textures/smoke_checker.ppm"
}

light {
    pos       = 0.0 1.2 0.0
    size      = 0.6 0.6 0.0
    emission  = 1.0 1.0 1.0
    intensity = 15.0
    enabled   = true
}
