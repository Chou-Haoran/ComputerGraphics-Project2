render {
    width   = 512
    height  = 512
    spp     = 16
    depth   = 6
    shadows = true
    bg      = 0.02 0.02 0.03
}

camera {
    pos     = 0.0 0.75 -1.2
    lookAt  = 0.0 0.0  0.0
    up      = 0.0 1.0  0.0
    fov     = 36
}

mesh "floor_uv.obj" {
    material     = MICROFACET
    color        = 0.80 0.76 0.70
    roughness    = 0.90
    diffuseTex   = "../../textures/smoke_checker.ppm"
    normalTex    = "../../textures/normal_debug.ppm"
    bumpTex      = "../../textures/roughness_debug.ppm"
    bumpScale    = 0.12
    roughnessTex = "../../textures/roughness_debug.ppm"
}

light {
    pos       = 0.0 1.3 -0.1
    size      = 0.7 0.7 0.0
    emission  = 1.0 1.0 1.0
    intensity = 18.0
    enabled   = true
}
