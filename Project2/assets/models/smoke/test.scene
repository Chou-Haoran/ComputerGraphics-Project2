# Smoke test: a floor quad plus an overhead area light. Use this to
# verify the SceneLoader / Renderer pipeline end-to-end without needing
# the desktop scene's full .obj set.
#
#   ./build/Project2Renderer assets/models/smoke test 256x256 16

render {
    width   = 256
    height  = 256
    spp     = 16
    depth   = 6
    shadows = true
    bg      = 0.02 0.02 0.03
}

camera {
    pos     = 0.0 0.6 -1.8
    lookAt  = 0.0 0.0  0.0
    up      = 0.0 1.0  0.0
    fov     = 40
}

mesh "floor.obj" {
    material = DIFFUSE
    color    = 0.8 0.8 0.8
}

light {
    pos       = 0.0 1.2 0.0
    size      = 0.6 0.6 0.0
    emission  = 1.0 1.0 1.0
    intensity = 15.0
    enabled   = true
}
