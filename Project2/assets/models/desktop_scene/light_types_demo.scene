# Demo scene for the analytic light types added to the .scene pipeline.
#
# Run from Project2/:
#   ./build/Project2Renderer assets/models/desktop_scene light_types_demo 800x600 64

render {
    width   = 800
    height  = 600
    spp     = 32
    depth   = 8
    shadows = true
    bg      = 0.020 0.020 0.026
}

camera {
    pos       = 0.055 0.040 0.120
    lookAt    = 0.000 0.016 -0.002
    up        = 0.0 1.0 0.0
    fov       = 28
    aperture  = 0.0
    focus     = 0.125
}

mesh "typewriter/typewriter.obj" {
    materialMap = "typewriter/typewriter.materialmap"
}

light {
    type      = DIRECTIONAL
    dir       = -0.30 -1.00 -0.22
    emission  = 1.00 0.97 0.92
    intensity = 0.28
    enabled   = true
}

light {
    type      = POINT
    pos       = 0.060 0.055 -0.030
    emission  = 0.88 0.92 1.00
    intensity = 0.00018
    range     = 0.20
    enabled   = true
}

light {
    type        = SPOT
    pos         = -0.055 0.095 0.020
    dir         = 0.35 -1.00 -0.10
    emission    = 1.00 0.92 0.84
    intensity   = 0.00045
    innerAngle  = 16.0
    outerAngle  = 28.0
    range       = 0.28
    enabled     = true
}
