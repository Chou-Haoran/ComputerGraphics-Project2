# Front view of the vintage desktop scene.
# Paths inside this file resolve relative to this .scene's directory
# (assets/models/desktop_scene/). Until the .obj exports are dropped in,
# SceneLoader logs a "not found" warning per mesh and keeps going — the
# scene / camera / lights still build, so you can verify the pipeline
# with just the light(s) visible against the background.

render {
    width   = 1024
    height  = 768
    spp     = 256
    depth   = 8
    shadows = true
    bg      = 0.02 0.02 0.025
}

camera {
    pos       = 0.0 0.45 -1.10
    lookAt    = 0.0 0.10  0.00
    up        = 0.0 1.00  0.00
    fov       = 35
    aperture  = 0.012
    focus     = 1.10
}

envmap "../../envmaps/studio_warm_2k.hdr" {
    intensity = 0.4
}

mesh "table.obj"      { material = MICROFACET color = 0.45 0.30 0.20 roughness = 0.45 diffuseTex = "../../textures/wood_diffuse.png" normalTex = "../../textures/wood_normal.png" }
# Drop the user's OBJ/MTL plus any referenced images under
# assets/models/desktop_scene/typewriter/.
mesh "typewriter/typewriter.obj" { }
mesh "phone.obj"      { material = MICROFACET color = 0.05 0.05 0.05 roughness = 0.20 }
mesh "paper.obj"      { material = DIFFUSE    color = 0.95 0.92 0.88 diffuseTex = "../../textures/paper_diffuse.png" }

light {
    pos       = 0.0 0.80 0.0
    size      = 0.30 0.30 0.0
    emission  = 1.00 0.95 0.85
    intensity = 35.0
    enabled   = true
}
