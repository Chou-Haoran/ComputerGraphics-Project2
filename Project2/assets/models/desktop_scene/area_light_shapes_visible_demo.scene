# Demo scene for visible AREA_DISK and AREA_SPHERE light models.
#
# Run from Project2/:
#   ./build/Project2Renderer assets/models/desktop_scene area_light_shapes_visible_demo 800x600 64

render {
    width   = 800
    height  = 600
    spp     = 32
    depth   = 8
    shadows = true
    bg      = 0.018 0.018 0.024
}

camera {
    pos       = 0.080 0.050 0.130
    lookAt    = 0.000 0.016 -0.002
    up        = 0.0 1.0 0.0
    fov       = 28
    aperture  = 0.0
    focus     = 0.140
}

mesh "typewriter/typewriter.obj" {
    materialMap = "typewriter/typewriter.materialmap"
}

light {
    type      = AREA_DISK
    pos       = 0.000 0.115 -0.005
    normal    = 0.000 -1.000 0.000
    radius    = 0.040
    emission  = 1.00 0.97 0.92
    intensity = 18.0
    showModel = true
    enabled   = true
}

light {
    type      = AREA_SPHERE
    pos       = 0.070 0.070 -0.035
    radius    = 0.018
    emission  = 0.88 0.92 1.00
    intensity = 4.5
    showModel = true
    enabled   = true
}
