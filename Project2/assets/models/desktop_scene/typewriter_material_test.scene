# Typewriter material test scene.
# Intentionally assigns different internal material models to visible sub-parts
# of the same asset so the renderer's current material implementations can be
# compared in one frame.
#
# Run from Project2/:
#   ./build/Project2Renderer assets/models/desktop_scene typewriter_material_test 960x720 64

render {
    width   = 960
    height  = 720
    spp     = 64
    depth   = 8
    shadows = true
    bg      = 0.040 0.040 0.048
}

camera {
    pos       = 0.000 0.026 0.118
    lookAt    = 0.000 0.014 0.000
    up        = 0.0 1.0 0.0
    fov       = 26
    aperture  = 0.0
    focus     = 0.118
}

envmap "../../envmaps/typewriter_studio_soft.hdr" {
    intensity = 0.24
}

mesh "typewriter/typewriter.obj" {
    materialMap = "typewriter/typewriter_material_test.materialmap"
}

light {
    pos       = -0.012 0.085 -0.030
    size      = 0.075 0.060 0.0
    emission  = 1.00 0.97 0.90
    intensity = 24.0
    enabled   = true
}

light {
    pos       = 0.062 0.052 -0.040
    size      = 0.032 0.032 0.0
    emission  = 0.86 0.91 1.00
    intensity = 6.0
    enabled   = true
}

light {
    pos       = -0.055 0.048 0.030
    size      = 0.028 0.028 0.0
    emission  = 1.00 0.92 0.84
    intensity = 5.0
    enabled   = true
}
